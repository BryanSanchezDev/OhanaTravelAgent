{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es6",
    "outDir": "dist",
    "rootDir": ".",
    "sourceMap": true,
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["es6"],
    "types": ["node"]
  },
  "include": [
    "*.ts",
    "chat/*.ts",
    "get-roles/*.ts",
    "generate-token/*.ts",
    "validate-token/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}